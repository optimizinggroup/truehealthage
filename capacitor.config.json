{
  "appId": "com.optimizinggroup.truehealthage",
  "appName": "True Health Age",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "backgroundColor": "#0D9488",
  "ios": {
    "scheme": "True Health Age",
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#0D9488",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "light",
      "backgroundColor": "#0D9488"
    },
    "Preferences": {
      "group": "TrueHealthAgePrefs"
    }
  }
}
